#include <stdio.h>
#include "altera_up_sd_card_avalon_interface.h"

#define WIDTH   320
#define HEIGHT  240

static int rd8(short int fd)
{
    return alt_up_sd_card_read(fd);
}

int main()
{
    alt_up_sd_card_dev *sd_dev;
    short int fd;
    int x, y;
    int b, g, r;

    sd_dev = alt_up_sd_card_open_dev("/dev/SDCard");
    if (sd_dev == NULL) {
        printf("Khong mo duoc SD\n");
        return 1;
    }

    if (!alt_up_sd_card_is_Present()) {
        printf("Khong co the SD\n");
        return 1;
    }

    if (!alt_up_sd_card_is_FAT16()) {
        printf("Khong phai FAT16\n");
        return 1;
    }

    fd = alt_up_sd_card_fopen("CAYCOI.BMP", false);
    if (fd < 0) {
        printf("Mo file loi\n");
        return 1;
    }

    // Bo qua 138 byte header
    for (int i = 0; i < 138; i++) {
        if (rd8(fd) < 0) {
            printf("Loi doc header\n");
            alt_up_sd_card_fclose(fd);
            return 1;
        }
    }

    for (y = 0; y < HEIGHT; y++) {
        for (x = 0; x < WIDTH; x++) {
            b = rd8(fd);
            g = rd8(fd);
            r = rd8(fd);

            if (b < 0 || g < 0 || r < 0) {
                printf("Loi doc pixel tai x=%d y=%d\n", x, y);
                alt_up_sd_card_fclose(fd);
                return 1;
            }

            // In thử 10 pixel đầu tiên
            if (y == 0 && x < 10) {
                printf("Pixel[%d,%d] = R=%3d G=%3d B=%3d\n",
                       x, y, r, g, b);
            }
        }
    }

    alt_up_sd_card_fclose(fd);
    printf("Doc xong anh BMP\n");
    return 0;
}

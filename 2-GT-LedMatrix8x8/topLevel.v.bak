module topLevel(
						input 	clock,
						output	[7:0] row,
						output	[7:0] col
	
);

reg [3:0] stt;
reg	[4:0] counter;


reg	[7:0]	data_row[10:0];
  
data_row[0] = 0xFF;
data_row[1] = 0x99;
data_row[2]	= 0x66;
data_row[3] = 0x7E;
data_row[4] = 0xBD;
data_row[5] = 0xDB;
data_row[6] = 0xE7;
data_row[7] = 0xFF;

endmodule



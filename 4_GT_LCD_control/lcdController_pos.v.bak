module lcdController_pos(
    input clk_50mhz,
    input rst_n,
    input start,              // Kích hoạt ghi LCD
    input clear,              // Kích hoạt xóa LCD
    input [3:0] col,          // Cột (0–15)
    input [1:0] row,          // Hàng (0 hoặc 1)
    input [7:0] data_in,      // Dữ liệu cần hiển thị
    output reg rs,
    output reg rw,
    output reg en,
    output reg [7:0] data,
    output [7:0] led_out
);

//==================== CLOCK 1ms ====================
reg [15:0] cnt_1ms;
reg tick_1ms;
always @(posedge clk_50mhz or negedge rst_n) begin
    if(!rst_n) begin
        cnt_1ms <= 0;
        tick_1ms <= 0;
    end else if (cnt_1ms == 16'd49999) begin
        cnt_1ms <= 0;
        tick_1ms <= 1;
    end else begin
        cnt_1ms <= cnt_1ms + 1;
        tick_1ms <= 0;
    end
end

//==================== STATE MACHINE ====================
parameter IDLE        = 3'd0;
parameter INIT_LCD    = 3'd1;
parameter SET_CURSOR  = 3'd2;
parameter WRITE_DATA  = 3'd3;
parameter CLEAR_LCD   = 3'd4;

reg [2:0] state;
reg [3:0] init_step;

//==================== MAIN FSM ====================
always @(posedge clk_50mhz or negedge rst_n) begin
    if(!rst_n) begin
        state <= INIT_LCD;
        init_step <= 0;
        rs <= 0; rw <= 0; en <= 0; data <= 8'h00;
    end
    else if(tick_1ms) begin
        case(state)
        //----------------------------------------------------------
        // 1️⃣ KHỞI TẠO LCD
        //----------------------------------------------------------
        INIT_LCD: begin
            case(init_step)
                0: begin rs<=0; rw<=0; data<=8'h38; en<=1; end // 8-bit, 2 dòng
                1: en<=0;
                2: begin data<=8'h0C; en<=1; end               // Bật hiển thị, tắt con trỏ
                3: en<=0;
                4: begin data<=8'h01; en<=1; end               // Xóa màn hình
                5: en<=0;
                6: begin data<=8'h06; en<=1; end               // Tăng địa chỉ tự động
                7: en<=0;
                8: if(start) state <= SET_CURSOR;
            endcase
            if(init_step < 8) init_step <= init_step + 1;
        end
        //----------------------------------------------------------
        // 2️⃣ XÓA MÀN HÌNH
        //----------------------------------------------------------
        CLEAR_LCD: begin
            rs <= 0;
            rw <= 0;
            data <= 8'h01;  // Lệnh clear LCD
            en <= 1;
            state <= IDLE;
        end
        //----------------------------------------------------------
        // 3️⃣ GỬI VỊ TRÍ CON TRỎ
        //----------------------------------------------------------
        SET_CURSOR: begin
            rs <= 0; rw <= 0;
            if(row == 0)
                data <= 8'h80 + col;
            else
                data <= 8'hC0 + col;

            en <= 1;
            state <= WRITE_DATA;
        end
        //----------------------------------------------------------
        // 4️⃣ GỬI DỮ LIỆU HIỂN THỊ
        //----------------------------------------------------------
        WRITE_DATA: begin
            en <= 0;
            rs <= 1; rw <= 0;
            data <= data_in;     // Gửi ký tự cần hiển thị
            en <= 1;
            state <= IDLE;
        end
        //----------------------------------------------------------
        // 5️⃣ DỪNG / CHỜ LỆNH
        //----------------------------------------------------------
        IDLE: begin
            en <= 0;
            if(clear) state <= CLEAR_LCD;  // Ưu tiên xóa
            else if(start) state <= SET_CURSOR;
        end
        endcase
    end
end

assign led_out = data;

endmodule

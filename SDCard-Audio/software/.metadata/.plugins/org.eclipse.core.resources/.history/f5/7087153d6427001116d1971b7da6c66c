#include <stdio.h>
#include <stdint.h>
#include <string.h>

static uint32_t rd32le(FILE *f)
{
    uint8_t b0 = fgetc(f);
    uint8_t b1 = fgetc(f);
    uint8_t b2 = fgetc(f);
    uint8_t b3 = fgetc(f);
    return ((uint32_t)b0) |
           ((uint32_t)b1 << 8) |
           ((uint32_t)b2 << 16) |
           ((uint32_t)b3 << 24);
}

static uint16_t rd16le(FILE *f)
{
    uint8_t b0 = fgetc(f);
    uint8_t b1 = fgetc(f);
    return (uint16_t)(b0 | (b1 << 8));
}

static int16_t rd16le_signed(FILE *f)
{
    return (int16_t)rd16le(f);
}

int main(void)
{
    FILE *f = fopen("AUDIO.WAV", "rb");
    char id[5];
    uint32_t size;
    uint16_t audio_format = 0, num_channels = 0, block_align = 0, bits_per_sample = 0;
    uint32_t sample_rate = 0, byte_rate = 0, data_size = 0;
    uint32_t num_frames;
    int found_fmt = 0, found_data = 0;
    int n;
    int16_t left, right;

    if (!f) {
        printf("Khong mo duoc file\n");
        return 1;
    }

    fread(id, 1, 4, f); id[4] = 0;   // RIFF
    if (strcmp(id, "RIFF") != 0) {
        printf("Khong phai RIFF\n");
        fclose(f);
        return 1;
    }

    size = rd32le(f);

    fread(id, 1, 4, f); id[4] = 0;   // WAVE
    if (strcmp(id, "WAVE") != 0) {
        printf("Khong phai WAVE\n");
        fclose(f);
        return 1;
    }

    // Dò từng chunk
    while (!found_fmt || !found_data) {
        if (fread(id, 1, 4, f) != 4) {
            printf("Khong tim thay du chunk can thiet\n");
            fclose(f);
            return 1;
        }
        id[4] = 0;
        size = rd32le(f);

        printf("Chunk: %s, size = %u\n", id, size);

        if (strcmp(id, "fmt ") == 0) {
            audio_format    = rd16le(f);
            num_channels    = rd16le(f);
            sample_rate     = rd32le(f);
            byte_rate       = rd32le(f);
            block_align     = rd16le(f);
            bits_per_sample = rd16le(f);

            // Nếu fmt chunk dài hơn 16 byte thì bỏ phần dư
            if (size > 16) {
                fseek(f, size - 16, SEEK_CUR);
            }

            found_fmt = 1;
        }
        else if (strcmp(id, "data") == 0) {
            data_size = size;
            found_data = 1;
            break; // con trỏ file đang đứng đúng đầu dữ liệu audio
        }
        else {
            // bỏ qua chunk không cần
            fseek(f, size, SEEK_CUR);
        }

        // WAV chunk thường word-aligned
        if (size & 1) {
            fseek(f, 1, SEEK_CUR);
        }
    }

    printf("audio_format    = %u\n", audio_format);
    printf("num_channels    = %u\n", num_channels);
    printf("sample_rate     = %u\n", sample_rate);
    printf("byte_rate       = %u\n", byte_rate);
    printf("block_align     = %u\n", block_align);
    printf("bits_per_sample = %u\n", bits_per_sample);
    printf("data_size       = %u\n", data_size);

    num_frames = data_size / block_align;
    printf("num_frames      = %u\n", num_frames);

    // đọc thử 10 frame đầu
    for (n = 0; n < 10 && n < (int)num_frames; n++) {
        if (num_channels == 2 && bits_per_sample == 16) {
            left  = rd16le_signed(f);
            right = rd16le_signed(f);
            printf("Frame %d: L=%d R=%d\n", n, left, right);
        }
    }

    fclose(f);
    return 0;
}

module top(
		input clk_50mhz,
		input reset,
		input key3,
		
		output oAUD_MCLK,
		output oAUD_BCLK,
		output oAUD_DACDAT,
		output oAUD_DACLRCK,
		input  iAUD_ADCDAT,
		output oAUD_ADCLRCK,
			
		output I2C_SLCK,
		inout  I2C_SDAT,
		output [15:0] led		// Hien THI DU LIEU DOC DUOC
);


wire clk_12mhz;
wire clk_512khz;
wire clk_100khz;
wire clk_16khz;
wire config_done;

pll u0(
	.inclk0(clk_50mhz),
	.c0(clk_12mhz),
	.c1(clk_512khz),
	.c2(clk_100khz)
	);

gen_lrclk_16k u1(
	 .BCLK(clk_512khz),       // 1.536 MHz
	 .reset(reset),
	 .LRCLK(clk_16khz)       	// 48 kHz
);

config_mic u2(
		.clock_50mhz(clk_50mhz),
		.clock_100khz(clk_100khz),
		.sda(I2C_SDAT),
		.scl(I2C_SLCK),
		.reset(reset),
		.enable_config(key3),
		.done_config(config_done),
		.o_index()
		);


endmodule







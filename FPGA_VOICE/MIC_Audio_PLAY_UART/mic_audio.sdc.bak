############################################################
# 1. CLOCK GỐC 50MHz (DE2-115)
############################################################
create_clock -name clk_50mhz -period 20.0 [get_ports clk_50mhz]

############################################################
# 2. PLL GENERATED CLOCKS (u2)
############################################################

# 12 MHz
create_generated_clock -name clk_12Mhz \
-source [get_ports clk_50mhz] \
[get_pins u2|altpll_component|auto_generated|pll1|clk[0]]

# 100 kHz
create_generated_clock -name clk_100Khz \
-source [get_ports clk_50mhz] \
[get_pins u2|altpll_component|auto_generated|pll1|clk[1]]

# 1.536 MHz
create_generated_clock -name clk_1536Mhz \
-source [get_ports clk_50mhz] \
[get_pins u2|altpll_component|auto_generated|pll1|clk[2]]

############################################################
# 3. 48kHz LRCLK (derived from 1.536 MHz)
############################################################

create_generated_clock -name clk_48khz \
-source [get_pins u1|BCLK] \
[get_pins u1|LRCLK]

############################################################
# 4. UART clock (nếu dùng clk_50mhz làm clock nội bộ)
############################################################
# Không cần thêm vì UART dùng clk_50mhz

############################################################
# 5. OPTIONAL - FALSE PATH giữa các clock domain
############################################################

# Không phân tích timing giữa audio 48kHz và 50MHz
set_clock_groups -asynchronous \
-group {clk_50mhz clk_12Mhz clk_100Khz clk_1536Mhz} \
-group {clk_48khz}
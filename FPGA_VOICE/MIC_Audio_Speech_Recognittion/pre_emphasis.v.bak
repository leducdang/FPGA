module pre_emphasis(
    input clk,
    input signed [15:0] x_in,
    output reg signed [15:0] y_out
);

parameter signed [15:0] ALPHA = 16'd31130; // 0.95 Q15
reg signed [15:0] x_prev;
reg signed [31:0] mult;

always @(posedge clk) begin
    mult <= ALPHA * x_prev;
    y_out <= x_in - (mult >>> 15);
    x_prev <= x_in;
end

endmodule




module high_pass_filter (
    input clk,
    input rst_n,
    input sample_valid,
    input signed [15:0] x_in,
    output reg signed [15:0] y_out
);

parameter signed [15:0] ALPHA = 16'sd31785; // 0.97 in Q15

reg signed [15:0] x_prev;
reg signed [15:0] y_prev;

reg signed [16:0] diff;
reg signed [17:0] sum;
reg signed [33:0] mult;

always @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
        x_prev <= 0;
        y_prev <= 0;
        y_out  <= 0;
    end
    else if (sample_valid) begin
        diff = x_in - x_prev;          // x[n] - x[n-1]
        sum  = y_prev + diff;          // y[n-1] + x[n] - x[n-1]
        mult = sum * ALPHA;            // Q15 multiply
        y_out <= mult >>> 15;          // back to 16-bit scale

        x_prev <= x_in;
        y_prev <= mult >>> 15;
    end
end

endmodule
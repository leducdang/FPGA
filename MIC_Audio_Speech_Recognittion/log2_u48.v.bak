module log2_u48
(
    input  wire        clk,
    input  wire        rst_n,
    input  wire        in_valid,
    input  wire [47:0] x,

    output reg         out_valid,
    output reg  [15:0] y   // Q6.10
);

parameter FRAC = 10;

reg [5:0]  exp;
reg [47:0] norm;
reg [7:0]  index;
reg [FRAC-1:0] frac;

reg nz;

// ---------------------------
// LUT ROM
// ---------------------------
reg [FRAC-1:0] log_lut [0:255];

initial begin
    $readmemh("log_lut.hex", log_lut);
end

// ---------------------------
// Leading One Detector
// ---------------------------
integer i;

always @(*) begin
    nz = 0;
    exp = 0;

    for(i=47;i>=0;i=i-1) begin
        if(!nz && x[i]) begin
            nz = 1;
            exp = i;
        end
    end
end


// ---------------------------
// Normalize mantissa
// ---------------------------
always @(posedge clk) begin

    if(!rst_n) begin
        norm <= 0;
        index <= 0;
    end
    else if(in_valid) begin

        norm <= x << (47-exp);

        // lấy 8 bit sau MSB
        index <= (x << (47-exp))[46:39];

    end
end


// ---------------------------
// LUT lookup
// ---------------------------
always @(posedge clk) begin

    frac <= log_lut[index];

end


// ---------------------------
// Output
// ---------------------------
always @(posedge clk) begin

    if(!rst_n) begin
        y <= 0;
        out_valid <= 0;
    end
    else begin
        out_valid <= in_valid;

        if(!nz)
            y <= 0;
        else
            y <= (exp << FRAC) + frac;

    end

end

endmodule



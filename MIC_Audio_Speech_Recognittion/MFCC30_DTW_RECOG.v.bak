module MFCC30_DTW_RECOG (
    input  wire clk,
    input  wire rst,              // active low

    input  wire mfcc_valid,
    input  wire [3:0] mfcc_index, // 0 -> 12
    input  wire signed [31:0] mfcc_in, // Q8.10

    output reg [2:0] result,      // 1 -> 4
    output reg recog_valid,
    output reg recog_done,
    output reg [63:0] best_distance
);

    parameter FRAME_N = 30;
    parameter MFCC_N  = 12;
    parameter DATA_N  = 360;

    // threshold normalized = 250
    // raw = 250 * 60 * 2^20
    parameter [63:0] THRESHOLD = 64'd15728640000;
    localparam INF = 64'h7FFFFFFFFFFFFFFF;

    reg signed [31:0] input_mem [0:DATA_N-1];

    reg signed [31:0] tpl1 [0:DATA_N-1];
    reg signed [31:0] tpl2 [0:DATA_N-1];
    reg signed [31:0] tpl3 [0:DATA_N-1];
    reg signed [31:0] tpl4 [0:DATA_N-1];

    initial begin
        $readmemh("template_1_30frame_mfcc1_12_q810_hex.hex", tpl1);
        $readmemh("template_2_30frame_mfcc1_12_q810_hex.hex", tpl2);
        $readmemh("template_3_30frame_mfcc1_12_q810_hex.hex", tpl3);
        $readmemh("template_4_30frame_mfcc1_12_q810_hex.hex", tpl4);
    end

    reg signed [31:0] frame_buf [0:11];
    reg [3:0] coeff_cnt;
    reg [5:0] frame_count;
    reg buffer_full;
    reg new_frame_ready;

    integer p, c;

    function signed [31:0] get_template;
        input [2:0] id;
        input [8:0] addr;
        begin
            case(id)
                3'd1: get_template = tpl1[addr];
                3'd2: get_template = tpl2[addr];
                3'd3: get_template = tpl3[addr];
                3'd4: get_template = tpl4[addr];
                default: get_template = 32'sd0;
            endcase
        end
    endfunction

    function [63:0] min3;
        input [63:0] a, b, c;
        begin
            if(a <= b && a <= c) min3 = a;
            else if(b <= a && b <= c) min3 = b;
            else min3 = c;
        end
    endfunction

    reg [63:0] prev [0:FRAME_N];
    reg [63:0] curr [0:FRAME_N];
    reg [63:0] dist [1:4];

    reg [5:0] i, j;
    reg [3:0] k;
    reg [2:0] tpl_id;

    reg [63:0] cost_acc;
    reg signed [32:0] diff;
    reg [65:0] diff_sq;
    reg [63:0] min_prev;

    reg dtw_busy;

    localparam IDLE      = 4'd0;
    localparam INIT      = 4'd1;
    localparam ROW_INIT  = 4'd2;
    localparam COST_INIT = 4'd3;
    localparam COST_MAC  = 4'd4;
    localparam CELL_DONE = 4'd5;
    localparam NEXT_CELL = 4'd6;
    localparam NEXT_ROW  = 4'd7;
    localparam SAVE_DIST = 4'd8;
    localparam NEXT_TPL  = 4'd9;
    localparam FIND_BEST = 4'd10;
    localparam DONE      = 4'd11;

    reg [3:0] state;

    always @(posedge clk or negedge rst) begin
        if(!rst) begin
            coeff_cnt <= 0;
            frame_count <= 0;
            buffer_full <= 0;
            new_frame_ready <= 0;

            result <= 0;
            recog_valid <= 0;
            recog_done <= 0;
            best_distance <= 0;

            state <= IDLE;
            dtw_busy <= 0;
        end
        else begin
            new_frame_ready <= 0;
            recog_done <= 0;
            recog_valid <= 0;

            // =============================
            // Nhận MFCC1 -> MFCC12
            // =============================
            if(mfcc_valid && mfcc_index >= 1 && mfcc_index <= 12) begin
                frame_buf[mfcc_index - 1] <= mfcc_in;

                if(mfcc_index == 12) begin
                    // Dịch buffer 30 frame
                    for(p = 0; p < FRAME_N-1; p = p + 1) begin
                        for(c = 0; c < MFCC_N; c = c + 1) begin
                            input_mem[p*MFCC_N + c] <= input_mem[(p+1)*MFCC_N + c];
                        end
                    end

                    // Ghi frame mới nhất vào vị trí cuối
                    for(c = 0; c < MFCC_N; c = c + 1) begin
                        if(c == 11)
                            input_mem[(FRAME_N-1)*MFCC_N + c] <= mfcc_in;
                        else
                            input_mem[(FRAME_N-1)*MFCC_N + c] <= frame_buf[c];
                    end

                    if(frame_count < FRAME_N)
                        frame_count <= frame_count + 1'b1;

                    if(frame_count >= FRAME_N-1) begin
                        buffer_full <= 1'b1;
                        new_frame_ready <= 1'b1;
                    end
                end
            end

            // =============================
            // DTW FSM
            // =============================
            case(state)

                IDLE: begin
                    dtw_busy <= 0;

                    if(buffer_full && new_frame_ready) begin
                        dtw_busy <= 1;
                        tpl_id <= 1;
                        state <= INIT;
                    end
                end

                INIT: begin
                    prev[0] <= 64'd0;

                    for(p = 1; p <= FRAME_N; p = p + 1)
                        prev[p] <= INF;

                    i <= 1;
                    state <= ROW_INIT;
                end

                ROW_INIT: begin
                    curr[0] <= INF;
                    j <= 1;
                    state <= COST_INIT;
                end

                COST_INIT: begin
                    k <= 0;
                    cost_acc <= 64'd0;
                    state <= COST_MAC;
                end

                COST_MAC: begin
                    diff = input_mem[(i-1)*MFCC_N + k] -
                           get_template(tpl_id, (j-1)*MFCC_N + k);

                    diff_sq = diff * diff;

                    cost_acc <= cost_acc + diff_sq[63:0];

                    if(k == MFCC_N-1)
                        state <= CELL_DONE;
                    else
                        k <= k + 1'b1;
                end

                CELL_DONE: begin
                    min_prev = min3(prev[j], curr[j-1], prev[j-1]);
                    curr[j] <= cost_acc + min_prev;
                    state <= NEXT_CELL;
                end

                NEXT_CELL: begin
                    if(j == FRAME_N)
                        state <= NEXT_ROW;
                    else begin
                        j <= j + 1'b1;
                        state <= COST_INIT;
                    end
                end

                NEXT_ROW: begin
                    for(p = 0; p <= FRAME_N; p = p + 1)
                        prev[p] <= curr[p];

                    if(i == FRAME_N)
                        state <= SAVE_DIST;
                    else begin
                        i <= i + 1'b1;
                        state <= ROW_INIT;
                    end
                end

                SAVE_DIST: begin
                    dist[tpl_id] <= curr[FRAME_N];
                    state <= NEXT_TPL;
                end

                NEXT_TPL: begin
                    if(tpl_id == 4)
                        state <= FIND_BEST;
                    else begin
                        tpl_id <= tpl_id + 1'b1;
                        state <= INIT;
                    end
                end

                FIND_BEST: begin
                    best_distance = dist[1];
                    result = 3'd1;

                    if(dist[2] < best_distance) begin
                        best_distance = dist[2];
                        result = 3'd2;
                    end

                    if(dist[3] < best_distance) begin
                        best_distance = dist[3];
                        result = 3'd3;
                    end

                    if(dist[4] < best_distance) begin
                        best_distance = dist[4];
                        result = 3'd4;
                    end

                    state <= DONE;
                end

                DONE: begin
                    recog_done <= 1'b1;

                    if(best_distance < THRESHOLD)
                        recog_valid <= 1'b1;
                    else
                        recog_valid <= 1'b0;

                    state <= IDLE;
                end

            endcase
        end
    end

endmodule




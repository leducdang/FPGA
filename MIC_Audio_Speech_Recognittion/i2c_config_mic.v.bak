module config_mic(
							clock_50mhz,
							clock_100khz,
							sda,
							scl,
							reset,
							enable_config,
							done_config,
							//test
							o_index
							);
							
//************* PORT *************//							
							
input clock_50mhz;
input clock_100khz;
output		scl;
inout			sda;
input 		reset;
input			enable_config;
output reg	done_config;
output	[7:0] o_index;

//************* VAR **************//

reg [4:0]	stt;
reg [6:0]  	index;
reg			i_GO;
reg [23:0]	i_i2c_data;
wire			o_END;
wire			ACK;
wire			SD_COUNTER;
wire			SDO;
reg [15:0] 	message[10:0];
wire			o_i2c_clk;

//************* data Config ******//

initial begin //collection of all adddresses and values to be written in the microphone
				//{address,data}
	 
	 
//*********************************************************************************//
	 
	message[0] <= 16'h1E00; // RESET
	message[1] <= 16'h0C00; // POWER DOWN CONTROL (all on)
	message[2] <= 16'h0E23; // DIGITAL AUDIO INTERFACE FORMAT (I2S, 16bit, slave)
	message[3] <= 16'h102F; // SAMPLING CONTROL (USB mode, 48k)
	message[4] <= 16'h0812; // ANALOG AUDIO PATH
	message[5] <= 16'h0A00; // DIGITAL AUDIO PATH
	message[6] <= 16'h0460; // LEFT HEADPHONE OUT
	message[7] <= 16'h0660; // RIGHT HEADPHONE OUT
	message[8] <= 16'h1201; // ACTIVE = 1 (BẬT CUỐI CÙNG)

//**********************************************************************************//	 
  end

always@(posedge clock_100khz or negedge reset)
begin
	//i_i2c_data <= {8'h42,8'h12,8'h80 };
	if(!reset)
		begin
			i_GO 	<= 0;
			stt  	<= 5'b111111;
			index <= 0;
			done_config <= 0;
		end
	else if(!enable_config && o_END == 0 )
			begin
				//i_GO 	<= 1;
				stt	<= 0;
			end
	else 
		case(stt)
					5'd0: begin i_GO <= 0; 
									stt <= 1; 
								end

					5'd1: if(!o_END)	stt <= 2; 
					5'd2:	begin 
									i_GO <= 1; 
									i_i2c_data <= {8'h34,message[index]}; 
									stt <= 3; 
								end
					5'd3: stt <= 4;
					5'd4:	if(o_END) 
							begin 
									i_GO <= 0; 
									stt <= 5;
									index <=  index + 1;	
								end
					5'd5: begin
								if(index > 8'd8)
									begin
										stt <= 6;
										done_config <= 1;
									end
								else
									begin
										stt <= 0;
									end
							end
				
				endcase				
end


i2c config_mic(
			 .CLOCK(clock_100khz),
			 .I2C_SCLK(o_i2c_clk),	//I2C CLOCK
			 .I2C_SDAT(sda),			//I2C DATA
			 .I2C_DATA(i_i2c_data),	//DATA:[SLAVE_ADDR,SUB_ADDR,DATA]
			 .GO(i_GO),      			//GO transfor
			 .END(o_END),    	    	//END transfor 
			 .W_R(),     				//W_R
			 .ACK(ACK),     	    	//ACK
			 .RESET(reset),
			 //TEST
			 .SD_COUNTER(SD_COUNTER),
			 .SDO(SDO)
		   	);

assign 	scl = 	o_i2c_clk;	
assign o_index = index;
endmodule

###############################################################################
# SDC for DE2-115 + OV7670 + PLL + SRAM + VGA
# Quartus Prime 17.1
###############################################################################

############################################
# 1. CLOCK NGUỒN 50 MHz
############################################
create_clock -name clk_50 \
    -period 20.000 \
    [get_ports clock_50mhz]


############################################
# 2. GENERATED CLOCK TỪ PLL
############################################
# PLL instance: u1
# c0 : 200 MHz  -> SRAM / Image Processing
# c1 : 24 MHz   -> XCLK_CAMERA (output only)
# c2 : 25 MHz   -> VGA
# c3 : 100 kHz  -> I2C SCCB

# 200 MHz
create_generated_clock -name clk_200 \
    -source [get_ports clock_50mhz] \
    [get_pins u1|altpll_component|pll1|clk[0]]

# 24 MHz XCLK camera (output)
create_generated_clock -name clk_cam_xclk \
    -source [get_ports clock_50mhz] \
    [get_ports XCLK_CAMERA]

# 25 MHz VGA
create_generated_clock -name clk_25 \
    -source [get_ports clock_50mhz] \
    [get_pins u1|altpll_component|pll1|clk[2]]

# 100 kHz I2C
create_generated_clock -name clk_100k \
    -source [get_ports clock_50mhz] \
    [get_pins u1|altpll_component|pll1|clk[3]]


############################################
# 3. CAMERA PIXEL CLOCK (ASYNC CLOCK)
############################################
# OV7670 PCLK ~24 MHz
create_clock -name cam_pclk \
    -period 41.667 \
    [get_ports PCLK_CAMERA]


############################################
# 4. KHAI BÁO ASYNCHRONOUS CLOCK GROUPS
############################################
# Camera clock hoàn toàn async với system clock

set_clock_groups -asynchronous \
    -group {clk_50 clk_200 clk_25 clk_100k clk_cam_xclk} \
    -group {cam_pclk}


############################################
# 5. FALSE PATH TỪ CAMERA DATA
############################################
# DATA, VSYNC, HREF đi theo cam_pclk
# Không check timing sang system clock

set_false_path -from [get_ports DATA_OUT_CAMERA[*]]
set_false_path -from [get_ports VSYNC_CAMERA]
set_false_path -from [get_ports HREF_CAMERA]


############################################
# 6. FIFO ASYNC (CAMERA -> SYSTEM)
############################################
# FIFO async đã xử lý CDC bên trong
# Không cần timing cross domain

set_false_path -through [get_cells *fifo*]


############################################
# 7. VGA OUTPUT (RELAX TIMING)
############################################
# VGA DAC không yêu cầu timing khắt khe

set_false_path -to [get_ports VGA_R[*]]
set_false_path -to [get_ports VGA_G[*]]
set_false_path -to [get_ports VGA_B[*]]
set_false_path -to [get_ports VGA_HS]
set_false_path -to [get_ports VGA_VS]


############################################
# 8. OPTIONAL: SRAM INTERFACE (NẾU TỰ ĐIỀU KHIỂN)
############################################
# Nếu dùng IP SRAM → có thể bỏ phần này

# set_output_delay -clock clk_200 2.0 [get_ports SRAM_ADDR[*]]
# set_output_delay -clock clk_200 2.0 [get_ports SRAM_WE_N]
# set_input_delay  -clock clk_200 2.0 [get_ports SRAM_DQ[*]]


############################################
# 9. END OF FILE
############################################
